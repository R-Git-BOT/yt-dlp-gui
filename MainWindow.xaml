<Window x:Class="YtDlpGui.MainWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:YtDlpGui.Infrastructure"
        Title="yt-dlp GUI"
        Width="1440"
        Height="960"
        MinWidth="1180"
        MinHeight="780"
        Background="#F7F9FC"
        FontFamily="Segoe UI, Yu Gothic UI, Meiryo"
        FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <infra:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <infra:BooleanToOpacityConverter x:Key="BoolToOpacity" />

        <SolidColorBrush x:Key="BorderBrush" Color="#D6DEE8" />
        <SolidColorBrush x:Key="TextBrush" Color="#1B2533" />
        <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TealBrush" Color="#0E6F73" />
        <SolidColorBrush x:Key="TealDarkBrush" Color="#07565A" />

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="132" />
            <Setter Property="Background" Value="{StaticResource TealBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TealDarkBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E8EEF5" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
        </Style>

        <Style x:Key="CategoryExpanderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid x:Name="HeaderRoot"
                              Height="42"
                              Background="{TemplateBinding Background}"
                              Cursor="Hand"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="68" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  Width="42"
                                  Height="42"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Viewbox Width="12"
                                         Height="12"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path x:Name="Arrow"
                                          Data="M 2,4 L 6,8 L 10,4"
                                          Stroke="#354154"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Square"
                                          StrokeEndLineCap="Square"
                                          StrokeLineJoin="Miter" />
                                </Viewbox>
                            </Grid>

                            <ContentPresenter Grid.Column="1"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />

                            <TextBlock Grid.Column="2"
                                       Margin="0,0,12,0"
                                       Text="{Binding SelectedCount, StringFormat=選択 {0}}"
                                       Foreground="{StaticResource MutedBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderRoot" Property="Background" Value="#F5F8FB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="HeaderRoot" Property="Background" Value="#EEF6F6" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Data" Value="M 2,8 L 6,4 L 10,8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="#FFFFFF"
                                BorderBrush="#E0E7F0"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ToggleButton Grid.Row="0"
                                              Style="{StaticResource CategoryExpanderToggleStyle}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                </ToggleButton>

                                <Border x:Name="ExpandSite"
                                        Grid.Row="1"
                                        BorderBrush="#E8EEF5"
                                        BorderThickness="0,1,0,0"
                                        ClipToBounds="True"
                                        MaxHeight="0"
                                        Opacity="0"
                                        Visibility="Collapsed"
                                        Background="#FFFFFF">
                                    <ContentPresenter Margin="0"
                                                      ContentSource="Content" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="MaxHeight" Value="1600" />
                                <Setter TargetName="ExpandSite" Property="Opacity" Value="1" />
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="MaxHeight" Value="0" />
                                <Setter TargetName="ExpandSite" Property="Opacity" Value="0" />
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding StartDownloadCommand}" />
        <KeyBinding Key="F6" Command="{Binding StopDownloadCommand}" />
    </Window.InputBindings>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="52"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="yt-dlp GUI"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="WPF"
                               Margin="12,2,0,0"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="コマンドプレビュー:"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="最新"
                               Margin="6,0,0,0"
                               Foreground="#087443"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="18,0,0,0"
                               Foreground="{StaticResource MutedBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="360"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding SaveSettingsCommand}" Content="設定を保存" />
                    <Button Command="{Binding LoadSettingsCommand}" Content="設定を読み込み" />
                    <Button Command="{Binding ResetCommand}" Content="リセット" />
                    <Button Command="{Binding CheckUpdatesCommand}" Content="アップデート確認" />
                    <Button Command="{Binding ShowVersionInfoCommand}" Content="バージョン情報" />
                    <Button Command="{Binding OpenHelpCommand}" Content="ヘルプ" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Left"
                Width="82"
                Visibility="Collapsed"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.SelectNavigationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Margin="8,3"
                                Padding="4,8"
                                BorderThickness="0"
                                Background="Transparent">
                            <TextBlock Text="{Binding}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       FontSize="12" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Height="44"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="yt-dlp:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBox Grid.Column="1"
                         Margin="8,7,18,7"
                         Text="{Binding YtDlpPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="2"
                           Text="保存先:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBox Grid.Column="3"
                         Margin="8,7,18,7"
                         Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="4"
                           Text="空欄ならyt-dlp既定。入力すると --paths に反映。"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBlock Grid.Column="5"
                           Text="{Binding SelectedOptionCount, StringFormat=選択中: {0}項目}"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextBrush}" />
                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding StartDownloadCommand}" Content="DL開始  F5" />
                    <Button Command="{Binding StopDownloadCommand}" Content="停止  F6" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="206" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <TextBlock Text="URL入力（複数行に対応）"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource TextBrush}" />
                        <Button DockPanel.Dock="Right" Command="{Binding FormatUrlListCommand}" Content="一覧形式に整形" />
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,10,0,8"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding UrlText, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBlock Text="{Binding UrlCount, StringFormat={}{0}件のURL}"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="有効: 入力行を順番に処理"
                                   Margin="14,0,0,0"
                                   Foreground="#087443" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="コマンドプレビュー（yt-dlp実行コマンド）"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <Button DockPanel.Dock="Right" Content="再読込" Command="{Binding RefreshOptionsCommand}" />
                    </DockPanel>
                    <TextBox Grid.Row="1"
                             Margin="0,10,0,0"
                             Text="{Binding CommandPreview, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="#075E35"
                             Background="#FBFEFC"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,10">
                            <TextBox Width="310"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="オプション名・説明から検索" />
                            <CheckBox Margin="14,0,0,0"
                                      Content="有効な項目のみ表示"
                                      IsChecked="{Binding ShowEnabledOnly}"
                                      VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" Command="{Binding RefreshOptionsCommand}" Content="yt-dlpから再読込" />
                        </DockPanel>

                        <ScrollViewer Grid.Row="1"
                                      Padding="0,0,14,0"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Header="{Binding Name}"
                                                  IsExpanded="{Binding IsExpanded}"
                                                  Style="{StaticResource CategoryExpanderStyle}"
                                                  Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">
                                            <Border Background="#FFFFFF">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border Margin="0,0,0,6"
                                                            Padding="10"
                                                            Background="#F8FBFD"
                                                            BorderBrush="#E2EAF3"
                                                            BorderThickness="0,0,0,1"
                                                            Visibility="{Binding IsFormatCategory, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Orientation="Horizontal">
                                                                <CheckBox Content="--format"
                                                                          IsChecked="{Binding DataContext.IsFormatBuilderEnabled, ElementName=Root}"
                                                                          VerticalAlignment="Center" />
                                                                <CheckBox Margin="18,0,0,0"
                                                                          Content="直接編集モード"
                                                                          IsChecked="{Binding DataContext.IsFormatDirectEdit, ElementName=Root}"
                                                                          VerticalAlignment="Center" />
                                                                <Button Margin="14,0,0,0"
                                                                        Padding="8,4"
                                                                        Content="セレクタ式の構文（外部サイト）"
                                                                        Command="{Binding DataContext.OpenFormatSelectionHelpCommand, ElementName=Root}"
                                                                        Visibility="{Binding DataContext.IsFormatDirectEdit, ElementName=Root, Converter={StaticResource BoolToVisibility}}" />
                                                            </StackPanel>

                                                            <Grid Grid.Row="1"
                                                                  Margin="0,10,0,0"
                                                                  Visibility="{Binding DataContext.IsFormatPresetMode, ElementName=Root, Converter={StaticResource BoolToVisibility}}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="170" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <ComboBox ItemsSource="{Binding DataContext.FormatPresets, ElementName=Root}"
                                                                          SelectedItem="{Binding DataContext.SelectedFormatPreset, ElementName=Root, Mode=TwoWay}"
                                                                          DisplayMemberPath="Name" />
                                                                <TextBlock Grid.Column="1"
                                                                           Margin="12,4,0,0"
                                                                           Text="{Binding DataContext.SelectedFormatPreset.Description, ElementName=Root}"
                                                                           TextWrapping="Wrap"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                            </Grid>

                                                            <Grid Grid.Row="2"
                                                                  Margin="0,10,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="10" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="10" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Text="解像度"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <ComboBox Grid.Row="1"
                                                                          Margin="0,4,0,0"
                                                                          ItemsSource="{Binding DataContext.FormatResolutions, ElementName=Root}"
                                                                          SelectedItem="{Binding DataContext.FormatResolution, ElementName=Root, Mode=TwoWay}" />

                                                                <TextBlock Grid.Column="2"
                                                                           Text="拡張子"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <ComboBox Grid.Row="1"
                                                                          Grid.Column="2"
                                                                          Margin="0,4,0,0"
                                                                          ItemsSource="{Binding DataContext.FormatExtensions, ElementName=Root}"
                                                                          SelectedItem="{Binding DataContext.FormatExtension, ElementName=Root, Mode=TwoWay}" />

                                                                <TextBlock Grid.Column="4"
                                                                           Text="サイズ"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <ComboBox Grid.Row="1"
                                                                          Grid.Column="4"
                                                                          Margin="0,4,0,0"
                                                                          ItemsSource="{Binding DataContext.FormatSizes, ElementName=Root}"
                                                                          SelectedItem="{Binding DataContext.FormatSize, ElementName=Root, Mode=TwoWay}" />
                                                            </Grid>

                                                            <Grid Grid.Row="3"
                                                                  Margin="0,10,0,0"
                                                                  Visibility="{Binding DataContext.IsFormatDirectEdit, ElementName=Root, Converter={StaticResource BoolToVisibility}}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="88" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="92" />
                                                                    <ColumnDefinition Width="120" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Text="--format"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <TextBox Grid.Column="1"
                                                                         Grid.ColumnSpan="3"
                                                                         Text="{Binding DataContext.FormatSelector, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" />

                                                                <TextBlock Grid.Row="1"
                                                                           Margin="0,8,0,0"
                                                                           Text="--format-sort"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <TextBox Grid.Row="1"
                                                                         Grid.Column="1"
                                                                         Grid.ColumnSpan="3"
                                                                         Margin="0,8,0,0"
                                                                         Text="{Binding DataContext.FormatSort, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" />

                                                                <TextBlock Grid.Row="2"
                                                                           Margin="0,8,0,0"
                                                                           Text="結合形式"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource MutedBrush}" />
                                                                <ComboBox Grid.Row="2"
                                                                          Grid.Column="1"
                                                                          Width="110"
                                                                          Margin="0,8,0,0"
                                                                          HorizontalAlignment="Left"
                                                                          ItemsSource="{Binding DataContext.FormatMergeOutputFormats, ElementName=Root}"
                                                                          SelectedItem="{Binding DataContext.MergeOutputFormat, ElementName=Root, Mode=TwoWay}" />
                                                                <StackPanel Grid.Row="2"
                                                                            Grid.Column="2"
                                                                            Grid.ColumnSpan="2"
                                                                            Margin="12,8,0,0"
                                                                            Orientation="Horizontal">
                                                                    <CheckBox Content="sort reset"
                                                                              IsChecked="{Binding DataContext.FormatSortReset, ElementName=Root}" />
                                                                    <CheckBox Margin="12,0,0,0"
                                                                              Content="sort force"
                                                                              IsChecked="{Binding DataContext.FormatSortForce, ElementName=Root}" />
                                                                </StackPanel>
                                                            </Grid>

                                                            <StackPanel Grid.Row="4"
                                                                        Margin="0,10,0,0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <CheckBox Content="複数映像ストリーム"
                                                                              IsChecked="{Binding DataContext.VideoMultistreams, ElementName=Root}" />
                                                                    <TextBlock Margin="4,0,0,0"
                                                                               Text="?"
                                                                               Width="16"
                                                                               Height="16"
                                                                               TextAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               ToolTip="複数の映像ストリームを1つの出力へ結合できるようにします。通常は1つの映像ストリームだけが使われます。" />
                                                                    <CheckBox Margin="16,0,0,0"
                                                                              Content="複数音声ストリーム"
                                                                              IsChecked="{Binding DataContext.AudioMultistreams, ElementName=Root}" />
                                                                    <TextBlock Margin="4,0,0,0"
                                                                               Text="?"
                                                                               Width="16"
                                                                               Height="16"
                                                                               TextAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               ToolTip="複数の音声ストリームを1つの出力へ結合できるようにします。複数言語音声などを残したい場合に使います。" />
                                                                </StackPanel>
                                                                <TextBlock Margin="0,8,0,0"
                                                                           Text="{Binding DataContext.FormatGeneratedArguments, ElementName=Root}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                          Foreground="#075E35" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <Border Margin="0,0,0,6"
                                                            Padding="10"
                                                            Background="#F8FBFD"
                                                            BorderBrush="#E2EAF3"
                                                            BorderThickness="0,0,0,1"
                                                            Visibility="{Binding IsOutputTemplateCategory, Converter={StaticResource BoolToVisibility}}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Orientation="Horizontal">
                                                                <CheckBox Content="--output"
                                                                          IsChecked="{Binding DataContext.IsOutputTemplateBuilderEnabled, ElementName=Root}"
                                                                          VerticalAlignment="Center" />
                                                                <Button Margin="14,0,0,0"
                                                                        Padding="8,4"
                                                                        Content="テンプレートに変更"
                                                                        Command="{Binding DataContext.ApplyDefaultOutputTemplateCommand, ElementName=Root}" />
                                                                <Button Margin="6,0,0,0"
                                                                        Padding="8,4"
                                                                        Content="ファイル名構文（外部サイト）"
                                                                        Command="{Binding DataContext.OpenOutputTemplateHelpCommand, ElementName=Root}" />
                                                            </StackPanel>

                                                            <TextBox Grid.Row="1"
                                                                     x:Name="OutputTemplateTextBox"
                                                             Margin="0,10,0,0"
                                                             FontFamily="Consolas"
                                                                     IsUndoEnabled="True"
                                                                     UndoLimit="100"
                                                                     PreviewKeyDown="OutputTemplateTextBox_PreviewKeyDown"
                                                                     TextChanged="OutputTemplateTextBox_TextChanged"
                                                             Text="{Binding DataContext.OutputTemplate, ElementName=Root, UpdateSourceTrigger=LostFocus}" />

                                                            <ItemsControl Grid.Row="2"
                                                                          Margin="0,10,0,0"
                                                                          ItemsSource="{Binding DataContext.OutputTemplateFields, ElementName=Root}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Margin="0,0,6,6"
                                                                                Padding="8,4"
                                                                                Content="{Binding Label}"
                                                                                Focusable="False"
                                                                                ToolTip="{Binding Description}"
                                                                                Tag="{Binding Token}"
                                                                                Click="OutputTemplateFieldButton_Click" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <TextBlock Grid.Row="3"
                                                                       Margin="0,4,0,0"
                                                                       Text="{Binding DataContext.OutputTemplateGeneratedArguments, ElementName=Root}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="#075E35" />
                                                        </Grid>
                                                    </Border>

                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Options}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid MinHeight="43"
                                                                  Margin="0,6,0,0"
                                                                  Opacity="{Binding IsVisible, Converter={StaticResource BoolToOpacity}}"
                                                                  Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="30" />
                                                                    <ColumnDefinition Width="172" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <CheckBox Grid.Column="0"
                                                                          Margin="10,4,0,0"
                                                                          IsChecked="{Binding IsSelected}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Margin="0,2,12,0"
                                                                           Text="{Binding PrimarySwitch}"
                                                                           FontFamily="Consolas"
                                                                           Foreground="#354154" />
                                                                <TextBlock Grid.Column="2"
                                                                           Margin="0,2,12,0"
                                                                           Text="{Binding Description}"
                                                                           TextWrapping="Wrap"
                                                                           Foreground="{StaticResource TextBrush}" />

                                                                <Grid Grid.Row="1"
                                                                      Grid.Column="2"
                                                                      Margin="0,7,12,0"
                                                                      Visibility="{Binding RequiresArgument, Converter={StaticResource BoolToVisibility}}">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="240" />
                                                                        <ColumnDefinition Width="12" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                             Visibility="{Binding UseTextInput, Converter={StaticResource BoolToVisibility}}" />
                                                                    <ComboBox ItemsSource="{Binding Choices}"
                                                                              SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                              Visibility="{Binding UseChoiceInput, Converter={StaticResource BoolToVisibility}}" />
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding ArgumentName}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               VerticalAlignment="Center" />
                                                                </Grid>

                                                                <Border Grid.Row="2"
                                                                        Grid.ColumnSpan="3"
                                                                        Margin="0,6,0,0"
                                                                        Height="1"
                                                                        Background="#EEF2F7" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.48*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="0.52*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="{Binding QueueSummary, StringFormat=キュー / 進捗（{0}）}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ClearQueueCommand}"
                                        Content="キューをクリア" />
                            </DockPanel>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Queue}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="42" />
                                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*" />
                                    <DataGridTextColumn Header="サイト" Binding="{Binding Site}" Width="120" />
                                    <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="110" />
                                    <DataGridTemplateColumn Header="進捗" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ProgressBar Width="74"
                                                                 Height="10"
                                                                 Maximum="100"
                                                                 Value="{Binding Progress}" />
                                                    <TextBlock Text="{Binding ProgressText}"
                                                               Margin="8,0,0,0"
                                                               Foreground="{StaticResource MutedBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="速度" Binding="{Binding Speed}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="出力ログ"
                                           FontWeight="SemiBold"
                                           FontSize="14" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Command="{Binding SaveLogCommand}" Content="ログを保存" />
                                    <Button Command="{Binding ClearLogCommand}" Content="ログをクリア" />
                                </StackPanel>
                            </DockPanel>
                            <TextBox Grid.Row="1"
                                     Text="{Binding LogText}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Background="#FCFCFD" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
